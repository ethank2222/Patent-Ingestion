# App
APP_ENV=development
APP_DEBUG=true
SECRET_KEY=change-me
PORT=8000

# Database and queue
DATABASE_URL=sqlite:///patents.db
REDIS_URL=redis://localhost:6379/0
RQ_ASYNC=true

# USPTO
USPTO_API_BASE=https://api.uspto.gov/api/v1
USPTO_API_KEY=
USPTO_TIMEOUT_SECONDS=30
USE_SAMPLE_DATA_ON_FAILURE=true
DEFAULT_INGEST_DAYS=30
DEFAULT_INGEST_LIMIT=500

# OpenAI
OPENAI_API_KEY=
OPENAI_SUMMARY_MODEL=gpt-4.1-mini
OPENAI_EXTRACT_MODEL=gpt-4.1-mini
PROMPT_VERSION=v1
SUMMARY_MAX_OUTPUT_TOKENS=1400

# Admin
ADMIN_API_TOKEN=change-me

# Frontend
VITE_API_BASE_URL=/api
